{
  "name": "fieldmap",
  "private": true,
  "version": "0.1.0",
  "description": "Fieldmap — offline field navigation app for Biologic Environmental. Capacitor + React.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "verify": "npm run typecheck && npm run build",
    "cap:sync": "npm run build && cap sync",
    "cap:ios": "npm run cap:sync && cap open ios",
    "cap:android": "npm run cap:sync && cap open android"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.23",
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/core": "^6.1.2",
    "@capacitor/filesystem": "^6.0.1",
    "@capacitor/geolocation": "^6.0.1",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/share": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1",
    "@capawesome/capacitor-file-picker": "^6.0.1",
    "@tmcw/togeojson": "^6.0.0",
    "dexie": "^4.0.8",
    "lucide-react": "^0.441.0",
    "maplibre-gl": "^4.7.1",
    "pmtiles": "^3.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shpjs": "^6.1.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@types/geojson": "^7946.0.14",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/shpjs": "^3.4.7",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.3"
  }
}
